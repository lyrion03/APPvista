<Window x:Class="APPvista.Desktop.HistoryComparisonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:APPvista.Desktop.Services"
        Title="{Binding WindowTitle}"
        Width="1280"
        Height="860"
        MinWidth="960"
        MinHeight="720"
        Background="#F5F0E6"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Window.Resources>
        <services:IconPathToImageSourceConverter x:Key="IconPathToImageSourceConverter" />

        <Style x:Key="OverviewMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="OverviewMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="#25433C" />
            <Setter Property="Foreground" Value="#FFF7EC" />
            <Setter Property="BorderBrush" Value="#2F534A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True" />
                                <Path x:Name="Arrow"
                                      Grid.Column="1"
                                      Margin="14,0,14,0"
                                      VerticalAlignment="Center"
                                      Fill="{TemplateBinding Foreground}"
                                      Data="M 0 0 L 4 4 L 0 8 Z"
                                      Visibility="Collapsed" />
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PopupAnimation="Fade">
                                    <Border Margin="0,8,0,0"
                                            Background="#25433C"
                                            BorderBrush="#2F534A"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#31574D" />
                                <Setter Property="Foreground" Value="#FFF7EC" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#31574D" />
                                <Setter Property="Foreground" Value="#FFF7EC" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#3E6B5F" />
                                <Setter Property="Foreground" Value="#FFF7EC" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8FA79A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#31574D" />
                    <Setter Property="Foreground" Value="#FFF7EC" />
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter Property="Background" Value="#31574D" />
                    <Setter Property="Foreground" Value="#FFF7EC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectorToggleStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="BorderBrush" Value="#D8CEBE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F8F1E4" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DCEBDE" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2D5E46" />
                                <Setter TargetName="Root" Property="BorderThickness" Value="2" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <ScrollViewer x:Name="WindowScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="22"
                    Background="#15312B"
                    BorderBrush="#21483D"
                    BorderThickness="1"
                    CornerRadius="26">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="0" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Foreground="#F3FAF6"
                                           FontSize="30"
                                           FontWeight="SemiBold"
                                           Text="{Binding WindowTitle}" />
                                <TextBlock Margin="28,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#C5D7CF"
                                           FontSize="14"
                                           Text="{Binding RangeDisplay}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right">
                            <StackPanel Orientation="Horizontal">
                                <Menu Margin="0,0,26,0"
                                      Style="{StaticResource OverviewMenuStyle}">
                                    <Menu.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#31574D" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#31574D" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#25433C" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFF7EC" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFF7EC" />
                                        <Style TargetType="MenuItem" BasedOn="{StaticResource OverviewMenuItemStyle}" />
                                    </Menu.Resources>
                                    <MenuItem Header="{Binding ApplicationSortMenuDisplay}"
                                              Style="{StaticResource OverviewMenuItemStyle}">
                                        <MenuItem Header="名称"
                                                  Command="{Binding SetSortByNameCommand}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding IsSortByNameMode, Mode=OneWay}" />
                                        <MenuItem Header="前台时长"
                                                  Command="{Binding SetSortByForegroundDurationCommand}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding IsSortByForegroundDurationMode, Mode=OneWay}" />
                                        <MenuItem Header="前台占比"
                                                  Command="{Binding SetSortByForegroundRatioCommand}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding IsSortByForegroundRatioMode, Mode=OneWay}" />
                                        <MenuItem Header="平均工作集"
                                                  Command="{Binding SetSortByAverageWorkingSetCommand}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding IsSortByAverageWorkingSetMode, Mode=OneWay}" />
                                        <MenuItem Header="平均cpu"
                                                  Command="{Binding SetSortByAverageCpuCommand}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding IsSortByAverageCpuMode, Mode=OneWay}" />
                                        <MenuItem Header="总流量"
                                                  Command="{Binding SetSortByTotalTrafficCommand}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding IsSortByTotalTrafficMode, Mode=OneWay}" />
                                        <MenuItem Header="I/O总量"
                                                  Command="{Binding SetSortByTotalIoCommand}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding IsSortByTotalIoMode, Mode=OneWay}" />
                                        <MenuItem Header="平均IOPS"
                                                  Command="{Binding SetSortByAverageIopsCommand}"
                                                  IsCheckable="True"
                                                  IsChecked="{Binding IsSortByAverageIopsMode, Mode=OneWay}" />
                                    </MenuItem>
                                </Menu>
                                <Button Padding="12,6"
                                        Margin="0,0,10,0"
                                        Background="#21483D"
                                        BorderBrush="#6EA08F"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        Command="{Binding ToggleAllApplicationsCommand}"
                                        Content="{Binding ToggleAllApplicationsText}"
                                        Foreground="#E8F4EE"
                                        FontSize="12"
                                        FontWeight="SemiBold" />
                                <Grid>
                                    <ToggleButton x:Name="MetricSelectorButton"
                                                  Padding="16,10"
                                                  Background="#21483D"
                                                  BorderBrush="#6EA08F"
                                                  BorderThickness="1"
                                                  FontSize="13"
                                                  FontWeight="SemiBold"
                                                  Foreground="#E8F4EE"
                                                  IsChecked="{Binding IsMetricSelectorOpen, Mode=TwoWay}"
                                                  Content="显示指标" />
                                    <Popup PlacementTarget="{Binding ElementName=MetricSelectorButton}"
                                           Placement="Bottom"
                                           IsOpen="{Binding IsMetricSelectorOpen}"
                                           StaysOpen="False">
                                        <Border Margin="0,8,0,0"
                                                Padding="14"
                                                Background="#FFFDF9"
                                                BorderBrush="#D8CEBE"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <StackPanel>
                                                <TextBlock Foreground="#213B35"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Text="选择显示指标" />
                                                <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding VisibleMetrics}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Margin="0,4,0,0"
                                                                      Foreground="#46534C"
                                                                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                      Content="{Binding DisplayName}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </StackPanel>
                            <TextBlock Margin="0,8,0,0"
                                       HorizontalAlignment="Right"
                                       Foreground="#E1ECE6"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="{Binding SelectedApplicationsSummary}" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer x:Name="ApplicationSelectorScrollViewer"
                                  Grid.Row="2"
                                  Margin="0,14,0,0"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="220">
                        <ItemsControl ItemsSource="{Binding AvailableApplications}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ToggleButton Width="114"
                                                  Height="116"
                                                  Style="{StaticResource SelectorToggleStyle}"
                                                  PreviewMouseLeftButtonDown="ApplicationSelectorToggle_OnPreviewMouseLeftButtonDown"
                                                  PreviewMouseRightButtonDown="ApplicationSelectorToggle_OnPreviewMouseRightButtonDown"
                                                  ToolTip="左键拖动以扩选/反选&#10;右键点击进入历史信息页"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}">
                                        <StackPanel>
                                            <Border Width="40"
                                                    Height="40"
                                                    Margin="0,0,0,10"
                                                    HorizontalAlignment="Center"
                                                    Background="#F2ECE0"
                                                    CornerRadius="12">
                                                <Image Width="24"
                                                       Height="24"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       Stretch="Uniform"
                                                       Source="{Binding IconSourcePath, Converter={StaticResource IconPathToImageSourceConverter}}" />
                                            </Border>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Foreground="#213B35"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       MaxHeight="40" />
                                        </StackPanel>
                                    </ToggleButton>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Padding="18"
                    Background="#FFFDF9"
                    BorderBrush="#E2D8C8"
                    BorderThickness="1"
                    CornerRadius="26">
                <Grid>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#8B938B"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="请选择上方应用后查看详细对比">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedApplications}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasSelectedApplications}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="12" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Foreground="#213B35"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="平行坐标图" />

                            <ItemsControl Grid.Row="1"
                                          Margin="0,12,0,0"
                                          ItemsSource="{Binding ParallelChartSeries}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,12,8"
                                                Padding="10,6"
                                                Background="{Binding LegendBackground}"
                                                BorderBrush="{Binding LegendBorderBrush}"
                                                CornerRadius="14"
                                                Cursor="Hand"
                                                Opacity="{Binding LegendOpacity}"
                                                MouseEnter="ParallelChartSeriesElement_OnMouseEnter"
                                                MouseLeave="ParallelChartSeriesElement_OnMouseLeave">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderThickness" Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="12"
                                                        Height="12"
                                                        CornerRadius="6"
                                                        Background="{Binding Stroke}"
                                                        VerticalAlignment="Center" />
                                                <TextBlock Margin="6,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="#44514C"
                                                           FontSize="12"
                                                           Text="{Binding DisplayName}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontWeight" Value="Normal" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Grid Grid.Row="3">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#8B938B"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Text="{Binding ParallelChartHint}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasParallelChart}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <ScrollViewer x:Name="ParallelChartScrollViewer"
                                              HorizontalScrollBarVisibility="Auto"
                                              PreviewMouseWheel="ParallelChartScrollViewer_OnPreviewMouseWheel"
                                              Loaded="ParallelChartScrollViewer_OnLoaded"
                                              ScrollChanged="ParallelChartScrollViewer_OnScrollChanged"
                                              SizeChanged="ParallelChartScrollViewer_OnSizeChanged"
                                              VerticalScrollBarVisibility="Disabled">
                                            <ScrollViewer.Style>
                                                <Style TargetType="ScrollViewer">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasParallelChart}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ScrollViewer.Style>

                                            <Grid Width="{Binding ParallelChartHostWidth}"
                                                  Height="{Binding ParallelChartHeight}"
                                                  Background="Transparent">
                                                <Grid x:Name="ParallelChartSurface"
                                                      Width="{Binding ParallelChartWidth}"
                                                      Height="{Binding ParallelChartHeight}"
                                                      Background="Transparent"
                                                      HorizontalAlignment="Center"
                                                      MouseMove="ParallelChartSurface_OnMouseMove"
                                                      MouseLeave="ParallelChartSurface_OnMouseLeave">
                                                    <ItemsControl ItemsSource="{Binding ParallelChartAxes}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Width="1"
                                                                    Height="{Binding Height}"
                                                                    Background="#D7CCBC" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding ParallelChartSeries}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid>
                                                                <Polyline Points="{Binding Points}"
                                                                          Stroke="Transparent"
                                                                          StrokeThickness="18"
                                                                          StrokeLineJoin="Round"
                                                                          StrokeStartLineCap="Round"
                                                                          StrokeEndLineCap="Round"
                                                                          MouseEnter="ParallelChartSeriesElement_OnMouseEnter"
                                                                          MouseLeave="ParallelChartSeriesElement_OnMouseLeave" />
                                                                <Polyline Points="{Binding Points}"
                                                                          Stroke="{Binding Stroke}"
                                                                          StrokeThickness="{Binding StrokeThickness}"
                                                                          StrokeLineJoin="Round"
                                                                          StrokeStartLineCap="Round"
                                                                          StrokeEndLineCap="Round"
                                                                          Opacity="{Binding Opacity}"
                                                                          IsHitTestVisible="False" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding HighlightedParallelMarkers}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                                                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Ellipse Width="8"
                                                                     Height="8"
                                                                     Margin="-4,-4,0,0"
                                                                     Fill="#FFFDF9"
                                                                     Stroke="#213B35"
                                                                     StrokeThickness="2"
                                                                     IsHitTestVisible="False" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding HighlightedParallelMarkers}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding LabelLeft}" />
                                                            <Setter Property="Canvas.Top" Value="{Binding LabelTop}" />
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Padding="6,3"
                                                                    Width="{Binding LabelWidth}"
                                                                    Background="#FFFDF9"
                                                                    BorderBrush="#D8CEBE"
                                                                    BorderThickness="1"
                                                                    CornerRadius="10"
                                                                    IsHitTestVisible="False">
                                                                <TextBlock Foreground="#213B35"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Value}" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <ItemsControl ItemsSource="{Binding ParallelChartAxes}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <Canvas />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemContainerStyle>
                                                        <Style TargetType="ContentPresenter">
                                                            <Setter Property="Canvas.Left" Value="{Binding LabelLeft}" />
                                                            <Setter Property="Canvas.Top" Value="0" />
                                                        </Style>
                                                    </ItemsControl.ItemContainerStyle>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Width="{Binding LabelWidth}"
                                                                  Height="{Binding RelativeSource={RelativeSource AncestorType=ItemsControl}, Path=DataContext.ParallelChartHeight}">
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           Foreground="#213B35"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Text="{Binding Label}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Bottom"
                                                                           Margin="0,0,0,0"
                                                                           Foreground="#7F867F"
                                                                           FontSize="11"
                                                                           Text="{Binding MinLabel}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap" />
                                                                <TextBlock HorizontalAlignment="Center"
                                                                           VerticalAlignment="Top"
                                                                           Margin="0,18,0,0"
                                                                           Foreground="#7F867F"
                                                                           FontSize="11"
                                                                           Text="{Binding MaxLabel}"
                                                                           TextAlignment="Center"
                                                                           TextWrapping="Wrap" />
                                                                <Border Width="20"
                                                                        HorizontalAlignment="Center"
                                                                        Background="Transparent"
                                                                        Cursor="SizeWE"
                                                                        PreviewMouseLeftButtonDown="ParallelChartAxisHandle_OnPreviewMouseLeftButtonDown" />
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Grid>
                                </ScrollViewer>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
