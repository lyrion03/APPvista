<UserControl x:Class="APPvista.Desktop.HistoryPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:APPvista.Desktop.Services">
    <UserControl.Resources>
        <services:IconPathToImageSourceConverter x:Key="IconPathToImageSourceConverter" />

        <Style x:Key="HistoryDimensionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="122" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="Foreground" Value="#213B35" />
            <Setter Property="BorderBrush" Value="#D9D0C0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Margin="0,6,0,0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="24">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#F5EEE2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#E6DAC7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="108" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="14"
                Background="#15312B"
                CornerRadius="26">
            <StackPanel>
                <TextBlock Foreground="#D9E7DE"
                           FontSize="13"
                           HorizontalAlignment="Center"
                           Text="统计维度" />
                <Button Margin="0,16,0,0"
                        Command="{Binding SetHistoryDayDimensionCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource HistoryDimensionButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistoryDayDimension}" Value="True">
                                    <Setter Property="Background" Value="#D7E8DB" />
                                    <Setter Property="Foreground" Value="#15312B" />
                                    <Setter Property="BorderBrush" Value="#D7E8DB" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold" Text="日" />
                        <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" FontSize="10" Text="当日分析" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SetHistoryWeekDimensionCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource HistoryDimensionButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistoryWeekDimension}" Value="True">
                                    <Setter Property="Background" Value="#D7E8DB" />
                                    <Setter Property="Foreground" Value="#15312B" />
                                    <Setter Property="BorderBrush" Value="#D7E8DB" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold" Text="周" />
                        <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" FontSize="10" Text="区间汇总" />
                    </StackPanel>
                </Button>
                <Button Margin="0"
                        Command="{Binding SetHistoryMonthDimensionCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource HistoryDimensionButtonStyle}" TargetType="Button">
                            <Setter Property="Margin" Value="0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistoryMonthDimension}" Value="True">
                                    <Setter Property="Background" Value="#D7E8DB" />
                                    <Setter Property="Foreground" Value="#15312B" />
                                    <Setter Property="BorderBrush" Value="#D7E8DB" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold" Text="月" />
                        <TextBlock Margin="0,6,0,0" HorizontalAlignment="Center" FontSize="10" Text="趋势复盘" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="22"
                    Background="#FFFDF9"
                    CornerRadius="26">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Foreground="#7D8178" FontSize="13" Text="历史分析视图" />
                        <TextBlock Margin="0,8,0,0" Foreground="#213B35" FontSize="30" FontWeight="SemiBold" Text="{Binding HistoryDimensionHeadline}" />
                        <TextBlock Margin="0,10,0,0" Foreground="#526057" FontSize="14" Text="下方展示所选区间的汇总卡片与按应用 Top N 榜单，便于快速定位高流量、高 I/O 和前台占用应用。" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="14,10"
                            Background="#F7F1E6"
                            BorderBrush="#DDD1BE"
                            BorderThickness="1"
                            CornerRadius="20"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#6F766E"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="Top N（1-10）" />
                            <Border Margin="12,0,0,0"
                                    Width="48"
                                    Height="36"
                                    Background="#FFFDF9"
                                    BorderBrush="#D7CBB8"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#213B35"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Text="{Binding HistoryTopN}" />
                            </Border>
                            <Slider Margin="12,0,0,0"
                                    Width="220"
                                    VerticalAlignment="Center"
                                    Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding HistoryTopN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Padding="18"
                            Background="#25433C"
                            CornerRadius="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Foreground="#A9C0B2"
                                           FontSize="13"
                                           Text="历史区间日历" />
                                <TextBlock Margin="0,8,0,0"
                                           Foreground="#FFF7EC"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="{Binding HistoryCalendarSelectionDisplay}" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Width="28"
                                    Height="28"
                                    Background="#31574D"
                                    BorderBrush="#31574D"
                                    Command="{Binding ShowPreviousHistoryMonthCommand}"
                                    Content="&#x2039;"
                                    Cursor="Hand"
                                    FontSize="14"
                                    Foreground="#FFF7EC" />
                            <Button Grid.Column="3"
                                    Width="28"
                                    Height="28"
                                    Background="#31574D"
                                    BorderBrush="#31574D"
                                    Command="{Binding ShowNextHistoryMonthCommand}"
                                    Content="&#x203A;"
                                    Cursor="Hand"
                                    FontSize="14"
                                    Foreground="#FFF7EC" />
                        </Grid>
                    </Border>

                    <TextBlock Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               Foreground="#213B35"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="{Binding HistoryCalendarMonthDisplay}" />

                    <ItemsControl Margin="0,12,0,16"
                                  ItemsSource="{Binding HistoryCalendarDays}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Margin="0,0,6,6"
                                        MinHeight="32"
                                        Command="{Binding SelectCommand}"
                                        Content="{Binding DayNumber}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="18" Background="#FFFDF9" BorderBrush="#E6DBC9" BorderThickness="1" CornerRadius="24">
                            <StackPanel>
                                <TextBlock Foreground="#213B35" FontSize="18" FontWeight="SemiBold" Text="{Binding HistoryForegroundTopTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="#7D8178" FontSize="12" Text="按所选时间段累计前台时长排序" />
                                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding HistoryForegroundTopApplications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#15312B" FontSize="18" FontWeight="SemiBold" Text="{Binding Rank}" VerticalAlignment="Center" />
                                                <Image Grid.Column="1" Width="18" Height="18" Source="{Binding IconSourcePath, Converter={StaticResource IconPathToImageSourceConverter}}" Stretch="Uniform" />
                                                <TextBlock Grid.Column="2" Margin="8,0,10,0" Foreground="#213B35" FontSize="14" Text="{Binding ApplicationName}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Foreground="#48634E" FontSize="14" FontWeight="SemiBold" Text="{Binding MetricDisplay}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Padding="18" Background="#FFFDF9" BorderBrush="#E6DBC9" BorderThickness="1" CornerRadius="24">
                            <StackPanel>
                                <TextBlock Foreground="#213B35" FontSize="18" FontWeight="SemiBold" Text="{Binding HistoryTrafficTopTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="#7D8178" FontSize="12" Text="按所选时间段累计下载与上传总量排序" />
                                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding HistoryTrafficTopApplications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#15312B" FontSize="18" FontWeight="SemiBold" Text="{Binding Rank}" VerticalAlignment="Center" />
                                                <Image Grid.Column="1" Width="18" Height="18" Source="{Binding IconSourcePath, Converter={StaticResource IconPathToImageSourceConverter}}" Stretch="Uniform" />
                                                <TextBlock Grid.Column="2" Margin="8,0,10,0" Foreground="#213B35" FontSize="14" Text="{Binding ApplicationName}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Foreground="#7D5C31" FontSize="14" FontWeight="SemiBold" Text="{Binding MetricDisplay}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Padding="18" Background="#FFFDF9" BorderBrush="#E6DBC9" BorderThickness="1" CornerRadius="24">
                            <StackPanel>
                                <TextBlock Foreground="#213B35" FontSize="18" FontWeight="SemiBold" Text="{Binding HistoryIoTopTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="#7D8178" FontSize="12" Text="按所选时间段累计磁盘读取与写入总量排序" />
                                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding HistoryIoTopApplications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#15312B" FontSize="18" FontWeight="SemiBold" Text="{Binding Rank}" VerticalAlignment="Center" />
                                                <Image Grid.Column="1" Width="18" Height="18" Source="{Binding IconSourcePath, Converter={StaticResource IconPathToImageSourceConverter}}" Stretch="Uniform" />
                                                <TextBlock Grid.Column="2" Margin="8,0,10,0" Foreground="#213B35" FontSize="14" Text="{Binding ApplicationName}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Foreground="#2D5E46" FontSize="14" FontWeight="SemiBold" Text="{Binding MetricDisplay}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
