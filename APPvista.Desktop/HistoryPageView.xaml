<UserControl x:Class="APPvista.Desktop.HistoryPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:APPvista.Desktop.Services">
    <UserControl.Resources>
        <services:IconPathToImageSourceConverter x:Key="IconPathToImageSourceConverter" />

        <Style x:Key="HistoryDimensionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="98" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="Foreground" Value="#213B35" />
            <Setter Property="BorderBrush" Value="#D9D0C0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="24">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#F5EEE2" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#E6DAC7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="108" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="14"
                Background="#15312B"
                CornerRadius="26">
            <StackPanel>
                <TextBlock Foreground="#D9E7DE"
                           FontSize="18"
                           HorizontalAlignment="Center"
                           Text="统计维度" />
                <Button Command="{Binding SetHistoryDayDimensionCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource HistoryDimensionButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistoryDayDimension}" Value="True">
                                    <Setter Property="Background" Value="#D7E8DB" />
                                    <Setter Property="Foreground" Value="#15312B" />
                                    <Setter Property="BorderBrush" Value="#D7E8DB" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold" Text="日" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SetHistoryWeekDimensionCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource HistoryDimensionButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistoryWeekDimension}" Value="True">
                                    <Setter Property="Background" Value="#D7E8DB" />
                                    <Setter Property="Foreground" Value="#15312B" />
                                    <Setter Property="BorderBrush" Value="#D7E8DB" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold" Text="周" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding SetHistoryMonthDimensionCommand}">
                    <Button.Style>
                        <Style BasedOn="{StaticResource HistoryDimensionButtonStyle}" TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsHistoryMonthDimension}" Value="True">
                                    <Setter Property="Background" Value="#D7E8DB" />
                                    <Setter Property="Foreground" Value="#15312B" />
                                    <Setter Property="BorderBrush" Value="#D7E8DB" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel>
                        <TextBlock HorizontalAlignment="Center" FontSize="28" FontWeight="SemiBold" Text="月" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="22"
                    Background="#FFFDF9"
                    CornerRadius="26">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Margin="0,0,0,0" Foreground="#213B35" FontSize="30" FontWeight="SemiBold" Text="{Binding HistoryDimensionHeadline}" />
                        <TextBlock Margin="0,6,0,0" Foreground="#526057" FontSize="14" Text="下方展示所选区间的汇总卡片与按应用的 Top N 榜单，便于快速定位高流量、高 I/O 和前台占用应用。" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="128"
                            Padding="18,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Command="{Binding ShowHistoryComparisonCommand}"
                            Cursor="Hand"
                            Content="详细对比"
                            Foreground="#F5FBF7"
                            FontSize="17"
                            FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Root"
                                        Padding="{TemplateBinding Padding}"
                                        Background="#21483D"
                                        BorderBrush="#6EA08F"
                                        BorderThickness="1"
                                        CornerRadius="26"
                                        ToolTip="查看所选时段的应用详细信息对比">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="#285244" />
                                        <Setter TargetName="Root" Property="BorderBrush" Value="#89B3A4" />
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Root" Property="Background" Value="#183B31" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Border Grid.Column="1"
                            Margin="140,0,0,0"
                            Padding="14,10"
                            Background="#F7F1E6"
                            BorderBrush="#DDD1BE"
                            BorderThickness="1"
                            CornerRadius="20"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="#6F766E"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Text="Top N（3-10）" />
                            <Border Margin="12,0,0,0"
                                    Width="48"
                                    Height="36"
                                    Background="#FFFDF9"
                                    BorderBrush="#D7CBB8"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#213B35"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           Text="{Binding HistoryTopN}" />
                            </Border>
                            <Slider Margin="12,0,0,0"
                                    Width="220"
                                    VerticalAlignment="Center"
                                    Minimum="1"
                                    Maximum="10"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding HistoryTopN, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer x:Name="HistoryContentScrollViewer"
                          Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="18" Background="#FFFDF9" BorderBrush="#E6DBC9" BorderThickness="1" CornerRadius="24">
                            <StackPanel>
                                <TextBlock Foreground="#213B35" FontSize="18" FontWeight="SemiBold" Text="{Binding HistoryForegroundTopTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="#7D8178" FontSize="12" Text="按所选时间段累计前台时长排序" />
                                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding HistoryForegroundTopApplications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#15312B" FontSize="18" FontWeight="SemiBold" Text="{Binding Rank}" VerticalAlignment="Center" />
                                                <Image Grid.Column="1" Width="18" Height="18" Source="{Binding IconSourcePath, Converter={StaticResource IconPathToImageSourceConverter}}" Stretch="Uniform" />
                                                <TextBlock Grid.Column="2" Margin="8,0,10,0" Foreground="#213B35" FontSize="14" Text="{Binding ApplicationName}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Foreground="#48634E" FontSize="14" FontWeight="SemiBold" Text="{Binding MetricDisplay}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Margin="0,16,0,0"
                                        Padding="8"
                                        Background="#FCF8F1"
                                        BorderBrush="#E7DDCC"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Image Height="332"
                                           Stretch="Uniform"
                                           Source="{Binding HistoryForegroundPieChartSource}" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Padding="18" Background="#FFFDF9" BorderBrush="#E6DBC9" BorderThickness="1" CornerRadius="24">
                            <StackPanel>
                                <TextBlock Foreground="#213B35" FontSize="18" FontWeight="SemiBold" Text="{Binding HistoryTrafficTopTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="#7D8178" FontSize="12" Text="按所选时间段累计下载与上传总量排序" />
                                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding HistoryTrafficTopApplications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#15312B" FontSize="18" FontWeight="SemiBold" Text="{Binding Rank}" VerticalAlignment="Center" />
                                                <Image Grid.Column="1" Width="18" Height="18" Source="{Binding IconSourcePath, Converter={StaticResource IconPathToImageSourceConverter}}" Stretch="Uniform" />
                                                <TextBlock Grid.Column="2" Margin="8,0,10,0" Foreground="#213B35" FontSize="14" Text="{Binding ApplicationName}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Foreground="#7D5C31" FontSize="14" FontWeight="SemiBold" Text="{Binding MetricDisplay}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Margin="0,16,0,0"
                                        Padding="8"
                                        Background="#FCF8F1"
                                        BorderBrush="#E7DDCC"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Image Height="332"
                                           Stretch="Uniform"
                                           Source="{Binding HistoryTrafficPieChartSource}" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Padding="18" Background="#FFFDF9" BorderBrush="#E6DBC9" BorderThickness="1" CornerRadius="24">
                            <StackPanel>
                                <TextBlock Foreground="#213B35" FontSize="18" FontWeight="SemiBold" Text="{Binding HistoryIoTopTitle}" />
                                <TextBlock Margin="0,6,0,0" Foreground="#7D8178" FontSize="12" Text="按所选时间段累计磁盘读取与写入总量排序" />
                                <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding HistoryIoTopApplications}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="34" />
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#15312B" FontSize="18" FontWeight="SemiBold" Text="{Binding Rank}" VerticalAlignment="Center" />
                                                <Image Grid.Column="1" Width="18" Height="18" Source="{Binding IconSourcePath, Converter={StaticResource IconPathToImageSourceConverter}}" Stretch="Uniform" />
                                                <TextBlock Grid.Column="2" Margin="8,0,10,0" Foreground="#213B35" FontSize="14" Text="{Binding ApplicationName}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="3" Foreground="#2D5E46" FontSize="14" FontWeight="SemiBold" Text="{Binding MetricDisplay}" VerticalAlignment="Center" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Margin="0,16,0,0"
                                        Padding="8"
                                        Background="#FCF8F1"
                                        BorderBrush="#E7DDCC"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Image Height="332"
                                           Stretch="Uniform"
                                           Source="{Binding HistoryIoPieChartSource}" />
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
