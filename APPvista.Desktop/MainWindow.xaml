                                                Style="{StaticResource SortPopupButtonStyle}"
                                                Tag="{Binding IsSortByTrafficMode}"
                                                Command="{Binding SetSortByTrafficCommand}"
                                                Content="总流量" />
                                        <Button Margin="0,0,0,0"
