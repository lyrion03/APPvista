                        <Popup PlacementTarget="{Binding ElementName=SortButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsSortPopupOpen, Mode=TwoWay}">
                            <Border Width="560"
                                    Margin="0,8,0,0"
                                    Padding="18"
                                    Background="#25433C"
                                    CornerRadius="20">
                                <Border.Resources>
                                    <Style x:Key="SortPopupButtonStyle" TargetType="Button">
                                        <Setter Property="Padding" Value="10,8" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Setter Property="Foreground" Value="#EAF4ED" />
                                        <Setter Property="FontWeight" Value="Normal" />
                                        <Setter Property="BorderThickness" Value="0" />
                                        <Setter Property="Background" Value="#25433C" />
                                        <Setter Property="Margin" Value="0,0,0,0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
