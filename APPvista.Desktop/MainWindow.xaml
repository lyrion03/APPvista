                                <RowDefinition Height="8" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <UniformGrid Columns="7">
                                <Border Margin="0,0,8,0" Background="Transparent"><TextBlock HorizontalAlignment="Center" Foreground="#A9C0B2" Text="一" /></Border>
                                <Border Margin="0,0,8,0" Background="Transparent"><TextBlock HorizontalAlignment="Center" Foreground="#A9C0B2" Text="二" /></Border>
                                <Border Margin="0,0,8,0" Background="Transparent"><TextBlock HorizontalAlignment="Center" Foreground="#A9C0B2" Text="三" /></Border>
                                <Border Margin="0,0,8,0" Background="Transparent"><TextBlock HorizontalAlignment="Center" Foreground="#A9C0B2" Text="四" /></Border>
                                <Border Margin="0,0,8,0" Background="Transparent"><TextBlock HorizontalAlignment="Center" Foreground="#A9C0B2" Text="五" /></Border>
                                <Border Background="Transparent"><TextBlock HorizontalAlignment="Center" Foreground="#A9C0B2" Text="六" /></Border>
                                <Border Background="Transparent"><TextBlock HorizontalAlignment="Center" Foreground="#A9C0B2" Text="日" /></Border>
                            </UniformGrid>
                            <ItemsControl Grid.Row="2"
                                          ItemsSource="{Binding HistoryCalendarDays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Margin="0,0,0,4"
                                                Command="{Binding SelectCommand}"
                                                PreviewMouseLeftButtonDown="HistoryCalendarDayButton_OnPreviewMouseLeftButtonDown"
                                                Cursor="Hand">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Foreground" Value="#FFF7EC" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="Height" Value="30" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Segment"
                                                                        Background="Transparent"
                                                                        Margin="0"
                                                                        SnapsToDevicePixels="True"
                                                                        CornerRadius="0">
                                                                    <Border x:Name="Chip"
                                                                            Margin="1,0"
                                                                            Background="#1B352F"
                                                                            BorderBrush="#2E544A"
                                                                            BorderThickness="1"
                                                                            CornerRadius="8">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center" />
                                                                    </Border>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Chip" Property="Background" Value="#31574D" />
                                                                        <Setter TargetName="Chip" Property="BorderBrush" Value="#31574D" />
                                                                    </Trigger>
                                                                    <Trigger Property="IsEnabled" Value="False">
                                                                        <Setter TargetName="Chip" Property="Opacity" Value="0.55" />
                                                                    </Trigger>
                                                                    <DataTrigger Binding="{Binding IsInDisplayedMonth}" Value="False">
                                                                        <Setter Property="Foreground" Value="#6E8A80" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding HasData}" Value="True">
                                                                        <Setter TargetName="Chip" Property="Background" Value="#4F8A76" />
                                                                        <Setter TargetName="Chip" Property="BorderBrush" Value="#A7DCC8" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Foreground" Value="#15312B" />
                                                                        <Setter TargetName="Segment" Property="Background" Value="#A7D0BC" />
                                                                        <Setter TargetName="Chip" Property="Background" Value="Transparent" />
                                                                        <Setter TargetName="Chip" Property="BorderBrush" Value="Transparent" />
                                                                        <Setter TargetName="Chip" Property="BorderThickness" Value="0" />
                                                                        <Setter TargetName="Chip" Property="Margin" Value="0" />
                                                                        <Setter TargetName="Chip" Property="CornerRadius" Value="0" />
                                                                    </DataTrigger>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding IsSelected}" Value="True" />
                                                                            <Condition Binding="{Binding IsSelectable}" Value="False" />
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter TargetName="Chip" Property="Opacity" Value="1" />
                                                                    </MultiDataTrigger>
                                                                    <DataTrigger Binding="{Binding IsSingleSelection}" Value="True">
                                                                        <Setter TargetName="Segment" Property="Margin" Value="0" />
                                                                        <Setter TargetName="Segment" Property="CornerRadius" Value="8" />
                                                                        <Setter TargetName="Chip" Property="CornerRadius" Value="8" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsRangeStartOnly}" Value="True">
                                                                        <Setter TargetName="Segment" Property="Margin" Value="0,0,-4,0" />
                                                                        <Setter TargetName="Segment" Property="CornerRadius" Value="8,4,4,8" />
                                                                        <Setter TargetName="Chip" Property="CornerRadius" Value="8,4,4,8" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsRangeEndOnly}" Value="True">
                                                                        <Setter TargetName="Segment" Property="Margin" Value="-4,0,0,0" />
                                                                        <Setter TargetName="Segment" Property="CornerRadius" Value="4,8,8,4" />
                                                                        <Setter TargetName="Chip" Property="CornerRadius" Value="4,8,8,4" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsRangeMiddle}" Value="True">
                                                                        <Setter TargetName="Segment" Property="Margin" Value="-4,0,-4,0" />
                                                                        <Setter TargetName="Segment" Property="CornerRadius" Value="0" />
                                                                        <Setter TargetName="Chip" Property="CornerRadius" Value="0" />
                                                                    </DataTrigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Text="{Binding DayNumber}" />
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Grid>
                </Border>
                </Grid>
            </Border>
            <Border x:Name="DashboardHeaderTransitionOverlay"
