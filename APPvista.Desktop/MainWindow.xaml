                                        <Border Padding="10,6"
                                                Background="#31574D"
                                                CornerRadius="10">
                                            <TextBlock Foreground="#FFF7EC"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Text="使用情况" />
