<Window x:Class="APPvista.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:services="clr-namespace:APPvista.Desktop.Services"
        xmlns:local="clr-namespace:APPvista.Desktop"
        mc:Ignorable="d"
        Title="APPvista"
        Width="1800"
        Height="1010"
        MinWidth="1408"
        MinHeight="820"
        Icon="Assets/APPvista.ico"
        Background="#EEE6DA"
        FontFamily="Microsoft YaHei UI"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <services:IconPathToImageSourceConverter x:Key="IconPathToImageSourceConverter" />

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="MetricCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="#FFFDF9" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Margin" Value="0,0,14,0" />
        </Style>

        <Style x:Key="OverviewMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="OverviewMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="#25433C" />
            <Setter Property="Foreground" Value="#FFF7EC" />
            <Setter Property="BorderBrush" Value="#2F534A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True"
>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True" />
                                <Path x:Name="Arrow"
                                      Grid.Column="1"
                                      Margin="14,0,14,0"
                                      VerticalAlignment="Center"
                                      Fill="{TemplateBinding Foreground}"
                                      Data="M 0 0 L 4 4 L 0 8 Z"
                                      Visibility="Collapsed" />
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PopupAnimation="Fade">
                                    <Border Margin="0,8,0,0"
                                            Background="#25433C"
                                            BorderBrush="#2F534A"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#31574D" />
                                <Setter Property="Foreground" Value="#FFF7EC" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#31574D" />
                                <Setter Property="Foreground" Value="#FFF7EC" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#3E6B5F" />
                                <Setter Property="Foreground" Value="#FFF7EC" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8FA79A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#31574D" />
                    <Setter Property="Foreground" Value="#FFF7EC" />
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter Property="Background" Value="#31574D" />
                    <Setter Property="Foreground" Value="#FFF7EC" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="OverviewActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#25433C" />
            <Setter Property="Foreground" Value="#FFF7EC" />
            <Setter Property="BorderBrush" Value="#2F534A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#31574D" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#3E6B5F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8FA79A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DashboardSwitchButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="150" />
            <Setter Property="Height" Value="88" />
            <Setter Property="Margin" Value="0,0,14,0" />
            <Setter Property="Background" Value="#25433C" />
            <Setter Property="Foreground" Value="#FFF7EC" />
            <Setter Property="BorderBrush" Value="#355D53" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="26">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#2E554B" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#3E6B5F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="DashboardHeaderHost"
              Grid.Row="0"
              ClipToBounds="True">
            <Border x:Name="DashboardHeaderRoot"
                    Padding="28"
                    Background="#15312B"
                    CornerRadius="30">
                <Border.RenderTransform>
                    <TranslateTransform Y="0" />
                </Border.RenderTransform>
                <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <Grid Margin="0,18,0,0"
                          HorizontalAlignment="Left">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="DashboardSwitchIndicator"
                                Width="150"
                                Height="88"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Background="#FFF7EC"
                                CornerRadius="26"
                                IsHitTestVisible="False"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18"
                                                  Direction="270"
                                                  Opacity="0.18"
                                                  ShadowDepth="6"
                                                  Color="#0B1C18" />
                            </Border.Effect>
                            <Border.RenderTransform>
                                <TranslateTransform X="0" />
                            </Border.RenderTransform>
                        </Border>
                        <Button x:Name="RealtimeSwitchButton"
                                Grid.Column="0"
                                Click="RealtimeSwitchButton_OnClick"
                                Command="{Binding ShowRealtimePageCommand}">
                            <Button.Style>
                                <Style BasedOn="{StaticResource DashboardSwitchButtonStyle}" TargetType="Button">
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#FFF7EC" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RootBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="26">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                <Condition Binding="{Binding IsRealtimePageActive}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#2E554B" />
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsRealtimePageActive}" Value="True">
                                            <Setter Property="Foreground" Value="#15312B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Text="实时" />
                                <TextBlock Margin="0,6,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           Opacity="0.75"
                                           Text="应用监控仪表盘" />
                           </StackPanel>
                        </Button>
                        <Button x:Name="HistorySwitchButton"
                                Grid.Column="2"
                                Click="HistorySwitchButton_OnClick"
                                Command="{Binding ShowHistoryPageCommand}"
                                Margin="0">
                            <Button.Style>
                                <Style BasedOn="{StaticResource DashboardSwitchButtonStyle}" TargetType="Button">
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="Foreground" Value="#FFF7EC" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RootBorder"
                                                        Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="26">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                <Condition Binding="{Binding IsHistoryPageActive}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#2E554B" />
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsHistoryPageActive}" Value="True">
                                            <Setter Property="Foreground" Value="#15312B" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel>
                                <TextBlock HorizontalAlignment="Center"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Text="历史" />
                                <TextBlock Margin="0,6,0,0"
                                           HorizontalAlignment="Center"
                                           FontSize="12"
                                           Opacity="0.75"
                                           Text="分析页" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <Grid Margin="0,12,50,0"
                          HorizontalAlignment="Left">
                        <Menu x:Name="OverviewModeMenu"
                              Opacity="1"
                              Visibility="Visible"
                              IsHitTestVisible="True"
                              VerticalAlignment="Top"
                              Style="{StaticResource OverviewMenuStyle}">
                            <Menu.RenderTransform>
                                <TranslateTransform Y="0" />
                            </Menu.RenderTransform>
                            <Menu.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#31574D" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#31574D" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#25433C" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFF7EC" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFF7EC" />
                                <Style TargetType="MenuItem" BasedOn="{StaticResource OverviewMenuItemStyle}" />
                            </Menu.Resources>
                            <MenuItem Header="总览视图"
                                      Style="{StaticResource OverviewMenuItemStyle}">
                                <MenuItem Header="数据来源">
                                    <MenuItem Header="应用总和"
                                              Command="{Binding SetApplicationSumDataSourceCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsApplicationSumDataSourceMode, Mode=OneWay}" />
                                    <MenuItem Header="系统总量"
                                              Command="{Binding SetSystemTotalsDataSourceCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsSystemTotalsDataSourceMode, Mode=OneWay}" />
                                </MenuItem>
                                <MenuItem Header="网络显示">
                                    <MenuItem Header="总量"
                                              Command="{Binding SetNetworkTotalDisplayCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsNetworkTotalMode, Mode=OneWay}" />
                                    <MenuItem Header="区分上下行"
                                              Command="{Binding SetNetworkSplitDisplayCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsNetworkSplitMode, Mode=OneWay}" />
                                </MenuItem>
                                <MenuItem Header="IO显示">
                                    <MenuItem Header="总量"
                                              Command="{Binding SetIoTotalDisplayCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsIoTotalMode, Mode=OneWay}" />
                                    <MenuItem Header="区分读写"
                                              Command="{Binding SetIoSplitDisplayCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsIoSplitMode, Mode=OneWay}" />
                                </MenuItem>
                                <MenuItem Header="记录范围">
                                    <MenuItem Header="全部应用"
                                              Command="{Binding DisableWindowedOnlyRecordingCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsAllApplicationsRecordingMode, Mode=OneWay}" />
                                    <MenuItem Header="仅窗口应用"
                                              Command="{Binding EnableWindowedOnlyRecordingCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsWindowedOnlyRecordingMode, Mode=OneWay}" />
                                </MenuItem>
                                <MenuItem Header="卡片排序">
                                    <MenuItem Header="不随刷新重排"
                                              Command="{Binding SetCardReorderOffCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsCardReorderOffMode, Mode=OneWay}" />
                                    <MenuItem Header="随刷新重排"
                                              Command="{Binding SetCardReorderOnCommand}"
                                              IsCheckable="True"
                                              IsChecked="{Binding IsCardReorderOnMode, Mode=OneWay}" />
                                </MenuItem>
                            </MenuItem>
                        </Menu>
                        <Border x:Name="DashboardHistoryHeaderContent"
                                Margin="0,8,0,0"
                                Padding="16"
                                Background="#25433C"
                                CornerRadius="22"
                                MaxWidth="1000"
                                VerticalAlignment="Top"
                                Opacity="0"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <Border.RenderTransform>
                                <TranslateTransform Y="0" />
                            </Border.RenderTransform>
                            <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Margin="0,0,12,0">
                                    <TextBlock Margin="10,0,0,0"
                                               Foreground="#FFF7EC"
                                               FontSize="18"
                                               MaxHeight="46"
                                               FontWeight="SemiBold"
                                               Text="{Binding HistorySummaryCaption}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <Grid Grid.Column="2"
                                      HorizontalAlignment="Right"
                                      VerticalAlignment="Top">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Foreground="#CFE2D8"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               Text="网络数据" />
                                    <Border Margin="0,6,0,0"
                                            Padding="4"
                                            Background="#1D3C35"
                                            CornerRadius="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="74" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="74" />
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="HistoryNetworkSwitchIndicator"
                                                    Grid.Column="0"
                                                    Width="74"
                                                    VerticalAlignment="Stretch"
                                                    Background="#FFF7EC"
                                                    CornerRadius="10"
                                                    IsHitTestVisible="False">
                                                <Border.RenderTransform>
                                                    <TranslateTransform X="0" />
                                                </Border.RenderTransform>
                                            </Border>
                                            <Button x:Name="HistoryNetworkTotalButton"
                                                    Grid.Column="0"
                                                    Width="74"
                                                    Padding="12,6"
                                                    Click="HistoryNetworkTotalButton_OnClick"
                                                    Command="{Binding SetHistoryNetworkTotalDisplayCommand}"
                                                    Content="总量">
                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource GhostButtonStyle}" TargetType="Button">
                                                        <Setter Property="Foreground" Value="#A9C0B2" />
                                                        <Setter Property="FontSize" Value="12" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="RootBorder"
                                                                            Background="{TemplateBinding Background}"
                                                                            CornerRadius="10">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                                    <Condition Binding="{Binding IsHistoryNetworkTotalMode}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="#295148" />
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding IsHistoryNetworkTotalMode}" Value="True">
                                                                <Setter Property="Foreground" Value="#15312B" />
                                                                <Setter Property="Background" Value="#FFF7EC" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                            <Button x:Name="HistoryNetworkSplitButton"
                                                    Grid.Column="2"
                                                    Width="74"
                                                    Padding="12,6"
                                                    Click="HistoryNetworkSplitButton_OnClick"
                                                    Command="{Binding SetHistoryNetworkSplitDisplayCommand}"
                                                    Content="上下行">
                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource GhostButtonStyle}" TargetType="Button">
                                                        <Setter Property="Foreground" Value="#A9C0B2" />
                                                        <Setter Property="FontSize" Value="12" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="RootBorder"
                                                                            Background="{TemplateBinding Background}"
                                                                            CornerRadius="10">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                                    <Condition Binding="{Binding IsHistoryNetworkSplitMode}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="#295148" />
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding IsHistoryNetworkSplitMode}" Value="True">
                                                                <Setter Property="Foreground" Value="#15312B" />
                                                                <Setter Property="Background" Value="#FFF7EC" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Foreground="#CFE2D8"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               Text="IO 数据" />
                                    <Border Margin="0,6,0,0"
                                            Padding="4"
                                            Background="#1D3C35"
                                            CornerRadius="14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="74" />
                                                <ColumnDefinition Width="6" />
                                                <ColumnDefinition Width="74" />
                                            </Grid.ColumnDefinitions>
                                            <Border x:Name="HistoryIoSwitchIndicator"
                                                    Grid.Column="0"
                                                    Width="74"
                                                    VerticalAlignment="Stretch"
                                                    Background="#FFF7EC"
                                                    CornerRadius="10"
                                                    IsHitTestVisible="False">
                                                <Border.RenderTransform>
                                                    <TranslateTransform X="0" />
                                                </Border.RenderTransform>
                                            </Border>
                                            <Button x:Name="HistoryIoTotalButton"
                                                    Grid.Column="0"
                                                    Width="74"
                                                    Padding="12,6"
                                                    Click="HistoryIoTotalButton_OnClick"
                                                    Command="{Binding SetHistoryIoTotalDisplayCommand}"
                                                    Content="总量">
                                                <Button.Style>
                                                    <Style BasedOn="{StaticResource GhostButtonStyle}" TargetType="Button">
                                                        <Setter Property="Foreground" Value="#A9C0B2" />
                                                        <Setter Property="FontSize" Value="12" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                        <Setter Property="Background" Value="Transparent" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border x:Name="RootBorder"
                                                                            Background="{TemplateBinding Background}"
                                                                            CornerRadius="10">
                                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                                          VerticalAlignment="Center" />
                                                                    </Border>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                                    <Condition Binding="{Binding IsHistoryIoTotalMode}" Value="False" />
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Background" Value="#295148" />
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding IsHistoryIoTotalMode}" Value="True">
                                                                <Setter Property="Foreground" Value="#15312B" />
                                                                <Setter Property="Background" Value="#FFF7EC" />
