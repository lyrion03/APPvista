                                        <Button Margin="8,0,0,0"
                                                Padding="12,5"
                                                Background="#213B35"
                                                BorderBrush="#213B35"
                                                Command="{Binding SaveCustomMetricSelectionCommand}"
                                                Content="保存"
                                                Foreground="#FFF7EC"
                                                IsEnabled="{Binding CanSaveCustomMetricSelection}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>

                    <Grid Grid.Column="9">
                        <Button x:Name="BlacklistButton"
                                Style="{StaticResource OverviewActionButtonStyle}"
                                Command="{Binding ToggleBlacklistPopupCommand}"
                                Content="黑名单"
                                Foreground="#FFF7EC" />

                        <Popup PlacementTarget="{Binding ElementName=BlacklistButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsBlacklistPopupOpen, Mode=TwoWay}">
                            <Border Width="280"
                                    Margin="0,8,0,0"
                                    Padding="16"
                                    Background="#FFFDF9"
                                    BorderBrush="#D9D0C0"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <StackPanel>
                                    <TextBlock Foreground="#213B35"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="黑名单设置" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#647067"
                                               FontSize="12">
                                        <Run Text="勾选后仅从主列表隐藏；点击名称变红后" />
                                        <LineBreak />
                                        <Run Text="完全忽略该应用，并从历史统计与 TopN 排除" />
                                    </TextBlock>
                                    <ScrollViewer Margin="0,12,0,0"
                                                  MaxHeight="360"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding BlacklistCandidates}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox VerticalAlignment="Center"
                                                                  Visibility="{Binding CheckboxVisibility}"
                                                                  IsChecked="{Binding IsBlacklisted, Mode=TwoWay}" />
                                                        <Button Grid.Column="1"
                                                                Margin="8,0,0,0"
                                                                Padding="0"
                                                                HorizontalAlignment="Left"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                Command="{Binding ToggleIgnoredCommand}"
                                                                Cursor="Cross">
                                                            <TextBlock Foreground="{Binding NameForeground}"
                                                                       FontWeight="{Binding NameFontWeight}"
                                                                       Text="{Binding DisplayName}" />
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </Border>

                <ListBox x:Name="ApplicationsList"
                     Grid.Row="2"
                     Grid.ColumnSpan="2"
                     Background="Transparent"
                     BorderThickness="0"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     SizeChanged="ApplicationsList_OnSizeChanged"
                     ItemsSource="{Binding ApplicationRows}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="BorderThickness" Value="0" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{Binding CardWidth}"
                                    Height="256"
                                    Margin="0,0,16,16"
                                    Padding="18"
                                    Background="{Binding CardBackground}"
                                    BorderBrush="{Binding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="28"
                                    Cursor="Hand"
                                    ToolTip="{Binding IconToolTip}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding OpenDetailsCommand}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="60" />
                                        <RowDefinition Height="10" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="16" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="14" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <Grid Panel.ZIndex="2">
                                        <Grid.Style>
                                            <Style TargetType="Grid">
                                                <Setter Property="Panel.ZIndex" Value="2" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Panel.ZIndex" Value="8" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Grid.Style>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="54"
                                                Height="54"
                                                Background="#F5EBD8"
                                                CornerRadius="16">
                                            <Border Background="#F5EBD8"
                                                    CornerRadius="16">
                                                <Image Width="34"
                                                       Height="34"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Source="{Binding IconSourcePath, Converter={StaticResource IconPathToImageSourceConverter}}"
                                                       Stretch="Uniform" />
                                            </Border>
                                        </Border>

                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Foreground="#7D8178"
                                                       FontSize="12"
                                                       Text="{Binding StateDisplay}" />

                                            <Grid Margin="0,4,0,0">
                                                <Button Command="{Binding StartRenameCommand}"
                                                        ToolTip="{Binding NameToolTip}">
                                                    <Button.Style>
                                                        <Style BasedOn="{StaticResource GhostButtonStyle}" TargetType="Button">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock FontSize="20"
                                                               FontWeight="SemiBold"
                                                               Foreground="#213B35"
                                                               Text="{Binding DisplayName}"
                                                               TextWrapping="Wrap"
                                                               Height="44"
                                                               LineStackingStrategy="BlockLineHeight"
                                                               LineHeight="22" />
                                                </Button>

                                                <Grid>
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="8" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.Row="0"
                                                            Background="#FFF8EF"
                                                            BorderBrush="#C8D8CB"
                                                            BorderThickness="1"
                                                            CornerRadius="12">
                                                        <TextBox MinWidth="180"
                                                                 Padding="12,-2"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 FontSize="15"
                                                                 Foreground="#213B35"
                                                                 Text="{Binding EditableName, UpdateSourceTrigger=PropertyChanged}">
                                                            <TextBox.InputBindings>
                                                                <KeyBinding Key="Enter" Command="{Binding CommitRenameCommand}" />
                                                                <KeyBinding Key="Escape" Command="{Binding CancelRenameCommand}" />
                                                            </TextBox.InputBindings>
                                                        </TextBox>
                                                    </Border>

                                                    <StackPanel Grid.Row="2"
                                                                Orientation="Horizontal"
                                                                HorizontalAlignment="Left">
                                                        <Button MinWidth="58"
                                                                Padding="12,5"
                                                                Background="#213B35"
                                                                BorderBrush="#213B35"
                                                                Command="{Binding CommitRenameCommand}"
                                                                Content="保存"
                                                                Foreground="#FFF7EC" />
                                                        <Button Margin="8,0,0,0"
                                                                MinWidth="58"
                                                                Padding="12,5"
                                                                Background="#E7E1D3"
                                                                BorderBrush="#D8CFBE"
                                                                Command="{Binding CancelRenameCommand}"
                                                                Content="取消"
                                                                Foreground="#213B35" />
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>

                                    <ItemsControl Grid.Row="2"
                                                  Panel.ZIndex="1"
                                                  Margin="0,0,0,2"
                                                  ItemsSource="{Binding MetricCards}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <UniformGrid Columns="{Binding DataContext.MetricCardColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,10,10"
                                                        Background="#FFFFFF"
                                                        CornerRadius="18">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Padding" Value="12" />
                                                            <Setter Property="MinHeight" Value="72" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding DataContext.MetricCardColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="3">
                                                                    <Setter Property="Padding" Value="10,9" />
                                                                    <Setter Property="MinHeight" Value="68" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <TextBlock Foreground="#7D8178"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   Text="{Binding Label}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontSize" Value="11" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.MetricCardColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="3">
                                                                            <Setter Property="FontSize" Value="10" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Margin="0,6,0,0"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   TextWrapping="NoWrap"
                                                                   Text="{Binding Value}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="FontSize" Value="18" />
                                                                    <Setter Property="Margin" Value="0,6,0,0" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding DataContext.MetricCardColumns, RelativeSource={RelativeSource AncestorType=ItemsControl}}" Value="3">
                                                                            <Setter Property="FontSize" Value="15" />
                                                                            <Setter Property="Margin" Value="0,4,0,0" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <StackPanel Grid.Row="4">
                                        <TextBlock Foreground="#526057"
                                                   Text="{Binding UsageSummary}"
                                                   TextWrapping="Wrap" />
                                        <TextBlock Margin="0,10,0,0"
                                                   Foreground="#526057"
                                                   Text="{Binding PerformanceSummary}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="6"
                                               Foreground="#7D8178"
                                               FontSize="12"
                                               Text="点击卡片查看详情，点击名称可重命名" />
                                </Grid>
                            </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <Grid x:Name="HistoryPageRoot"
                  Opacity="0"
                  IsHitTestVisible="False"
                  Visibility="Collapsed"
                  Panel.ZIndex="0">
                <Grid.RenderTransform>
                    <TranslateTransform Y="0" />
                </Grid.RenderTransform>
                <ContentControl x:Name="HistoryPageHost" />
            </Grid>
        </Grid>

        <Border Grid.RowSpan="3"
                Panel.ZIndex="100"
                Background="#8A0F1E1A"
                Visibility="{Binding IsWindowedOnlyRecordingConfirmOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Border Width="460"
                        Padding="24"
                        Background="#FFFDF9"
                        BorderBrush="#D9D0C0"
                        BorderThickness="1"
                        CornerRadius="24"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="#213B35"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="切换为仅窗口应用记录？" />
                        <TextBlock Grid.Row="1"
                                   Margin="0,14,0,0"
                                   Foreground="#526057"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Text="继续后将删除当天无窗口应用的记录，且不可恢复。之后只会记录有窗口的应用；直到改回“全部应用”，才会从改回时开始重新记录所有应用。" />
                        <StackPanel Grid.Row="2"
                                    Margin="0,20,0,0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Padding="14,7"
                                    Background="Green"
                                    BorderBrush="#D8CFBE"
                                    Command="{Binding CancelEnableWindowedOnlyRecordingCommand}"
                                    Content="取消"
                                    Foreground="#FFF7EC" />
                            <Button Margin="10,0,0,0"
                                    Padding="14,7"
                                    Background="#B42318"
                                    BorderBrush="#B42318"
                                    Command="{Binding ConfirmEnableWindowedOnlyRecordingCommand}"
                                    Content="继续"
                                    Foreground="#FFF7EC" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
