                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsRangeStartOnly}" Value="True">
                                                                                            <Setter TargetName="Segment" Property="Margin" Value="0,0,-4,0" />
                                                                                            <Setter TargetName="Segment" Property="CornerRadius" Value="10,4,4,10" />
                                                                                            <Setter TargetName="Chip" Property="CornerRadius" Value="10,4,4,10" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsRangeEndOnly}" Value="True">
                                                                                            <Setter TargetName="Segment" Property="Margin" Value="-4,0,0,0" />
                                                                                            <Setter TargetName="Segment" Property="CornerRadius" Value="4,10,10,4" />
                                                                                            <Setter TargetName="Chip" Property="CornerRadius" Value="4,10,10,4" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsRangeMiddle}" Value="True">
                                                                                            <Setter TargetName="Segment" Property="Margin" Value="-4,0,-4,0" />
                                                                                            <Setter TargetName="Segment" Property="CornerRadius" Value="0" />
                                                                                            <Setter TargetName="Chip" Property="CornerRadius" Value="0" />
                                                                                        </DataTrigger>
                                                                                    </ControlTemplate.Triggers>
                                                                                </ControlTemplate>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Style>
                                                                </Button.Style>
                                                                <TextBlock Text="{Binding DayNumber}" />
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </Border>
                                    </Popup>
                                    </Grid>
                                </StackPanel>
                            </Grid>

                            <UniformGrid Margin="0,18,0,0"
                                         Columns="3">
                                <Border Margin="0,0,8,0"
                                        Padding="16"
                                        Background="#F5EFE3"
                                        CornerRadius="18">
                                    <StackPanel>
                                        <TextBlock Foreground="#7B7F74"
                                                   FontSize="12"
                                                   Text="总时长" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding HistoryUsageDisplay}" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="8,0,8,0"
                                        Padding="16"
                                        Background="#F4F0E7"
                                        CornerRadius="18">
                                    <StackPanel>
                                        <TextBlock Foreground="#7B7F74"
                                                   FontSize="12"
                                                   Text="前台时长" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding HistoryForegroundDurationDisplay}" />
                                    </StackPanel>
                                </Border>

                                <Border Margin="8,0,0,0"
                                        Padding="16"
                                        Background="#F1F6F0"
                                        CornerRadius="18">
                                    <StackPanel>
                                        <TextBlock Foreground="#7B7F74"
                                                   FontSize="12"
                                                   Text="前台占比" />
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding HistoryForegroundRatioDisplay}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0"
                        Padding="0"
                        Background="#FFFDF9"
                        CornerRadius="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Padding="18"
                                Background="#FFF8EF"
                                CornerRadius="18">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="#7B7F74"
                                               FontSize="12"
                                               Text="{Binding HistoryNetworkChartTitle}" />
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal">
                                        <TextBlock Margin="0,0,6,0"
                                                   Foreground="#C9812C"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="←"
                                                   Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowHistoryChartLeftHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Foreground="#C9812C"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="→"
                                                   Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowHistoryChartRightHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                                <Border Height="194"
                                        Margin="0,12,0,0"
                                        CornerRadius="14"
                                        ClipToBounds="True"
                                        Background="#FFF8EF">
                                    <ScrollViewer x:Name="HistoryNetworkChartScrollViewer"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  PanningMode="HorizontalOnly"
                                                  ScrollChanged="HistoryChartScrollViewer_OnScrollChanged"
                                                  SizeChanged="HistoryChartScrollViewer_OnSizeChanged"
                                                  PreviewMouseLeftButtonDown="HistoryChartScrollViewer_OnPreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="HistoryChartScrollViewer_OnPreviewMouseMove"
                                                  PreviewMouseLeftButtonUp="HistoryChartScrollViewer_OnPreviewMouseLeftButtonUp"
                                                  MouseLeave="HistoryChartScrollViewer_OnPreviewMouseLeftButtonUp">
                                        <Grid Width="{Binding HistoryChartDisplayWidth}">
                                            <Image Width="{Binding HistoryChartDisplayWidth}"
                                                   Height="180"
                                                   Margin="0,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Stretch="Uniform"
                                                   Source="{Binding HistoryNetworkChartSource}" />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="18"
                                Background="#F7FBF6"
                                CornerRadius="18">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Foreground="#7B7F74"
                                               FontSize="12"
                                               Text="{Binding HistoryIoChartTitle}" />
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal">
                                        <TextBlock Margin="0,0,6,0"
                                                   Foreground="#4D7F73"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="←"
                                                   Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowHistoryChartLeftHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <TextBlock Foreground="#4D7F73"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Text="→"
                                                   Visibility="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ShowHistoryChartRightHint, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </StackPanel>
                                </Grid>
                                <Border Height="194"
                                        Margin="0,12,0,0"
                                        CornerRadius="14"
                                        ClipToBounds="True"
                                        Background="#F7FBF6">
                                    <ScrollViewer x:Name="HistoryIoChartScrollViewer"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Disabled"
                                                  PanningMode="HorizontalOnly"
                                                  ScrollChanged="HistoryChartScrollViewer_OnScrollChanged"
                                                  SizeChanged="HistoryChartScrollViewer_OnSizeChanged"
                                                  PreviewMouseLeftButtonDown="HistoryChartScrollViewer_OnPreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="HistoryChartScrollViewer_OnPreviewMouseMove"
                                                  PreviewMouseLeftButtonUp="HistoryChartScrollViewer_OnPreviewMouseLeftButtonUp"
                                                  MouseLeave="HistoryChartScrollViewer_OnPreviewMouseLeftButtonUp">
                                        <Grid Width="{Binding HistoryChartDisplayWidth}">
                                            <Image Width="{Binding HistoryChartDisplayWidth}"
                                                   Height="180"
                                                   Margin="0,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Stretch="Uniform"
                                                   Source="{Binding HistoryIoChartSource}" />
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0"
                        Padding="22"
                        Background="#FFFDF9"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Foreground="#7B7F74"
                                   FontSize="13"
                                   Text="历史概况" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="16"
                                    Background="#F5EFE3"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock Foreground="#7B7F74"
                                               FontSize="12"
                                               Text="资源概况" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="{Binding HistoryAverageCpuDisplay, StringFormat=平均 CPU {0}}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding HistoryAverageIopsDisplay, StringFormat=平均 IOPS {0}}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding HistoryMemoryDisplay, StringFormat=内存 {0}}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding HistoryThreadDisplay, StringFormat=线程 {0}}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="16"
                                    Background="#EEF3ED"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock Foreground="#7B7F74"
                                               FontSize="12"
                                               Text="应用路径" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#506057"
                                               Text="{Binding HistoryExecutablePathDisplay, StringFormat=路径 {0}}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
