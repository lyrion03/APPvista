<Window x:Class="APPvista.Desktop.ApplicationDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:services="clr-namespace:APPvista.Desktop.Services"
        Title="APPvista - 应用详情"
        Width="980"
        Height="1080"
        MinWidth="980"
        MinHeight="520"
        Icon="Assets/APPvista.ico"
        Background="#F3EEE5"
        FontFamily="Microsoft YaHei UI"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <services:IconPathToImageSourceConverter x:Key="IconPathToImageSourceConverter" />
        <Style x:Key="OverviewMenuStyle" TargetType="Menu">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
        <Style x:Key="OverviewMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Background" Value="#25433C" />
            <Setter Property="Foreground" Value="#FFF7EC" />
            <Setter Property="BorderBrush" Value="#2F534A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True" />
                                <Path x:Name="Arrow"
                                      Grid.Column="1"
                                      Margin="14,0,14,0"
                                      VerticalAlignment="Center"
                                      Fill="{TemplateBinding Foreground}"
                                      Data="M 0 0 L 4 4 L 0 8 Z"
                                      Visibility="Collapsed" />
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                       Placement="Bottom"
                                       PopupAnimation="Fade">
                                    <Border Margin="0,8,0,0"
                                            Background="#25433C"
                                            BorderBrush="#2F534A"
                                            BorderThickness="1"
                                            CornerRadius="14">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Cycle" />
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Role" Value="SubmenuHeader">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Right" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelHeader">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                            </Trigger>
                            <Trigger Property="Role" Value="TopLevelItem">
                                <Setter TargetName="PART_Popup" Property="Placement" Value="Bottom" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#31574D" />
                                <Setter Property="Foreground" Value="#FFF7EC" />
                            </Trigger>
                            <Trigger Property="IsSubmenuOpen" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#31574D" />
                                <Setter Property="Foreground" Value="#FFF7EC" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#3E6B5F" />
                                <Setter Property="Foreground" Value="#FFF7EC" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8FA79A" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#31574D" />
                    <Setter Property="Foreground" Value="#FFF7EC" />
                </Trigger>
                <Trigger Property="IsSubmenuOpen" Value="True">
                    <Setter Property="Background" Value="#31574D" />
                    <Setter Property="Foreground" Value="#FFF7EC" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="18" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Padding="24"
                Background="#18352F"
                CornerRadius="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="24" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Width="76"
                        Height="76"
                        Background="#F5E8D3"
                        CornerRadius="22">
                    <Image Width="48"
                           Height="48"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Source="{Binding IconSourcePath, Converter={StaticResource IconPathToImageSourceConverter}}"
                           Stretch="Uniform" />
                </Border>

                <StackPanel Grid.Column="2">
                    <TextBlock Foreground="#D5E5DA"
                               FontSize="13"
                               Text="{Binding StateDisplay}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#FFF7EB"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Text="{Binding DisplayNameWithOriginal}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               Foreground="#F3C37B"
                               FontSize="15"
                               Text="{Binding TodayFocusRatio}" />
                </StackPanel>

                <Border Grid.Column="4"
                        Padding="0"
                        Background="#25433C"
                        CornerRadius="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="104" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="104" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="DetailDataSwitchIndicator"
                                Grid.Column="0"
                                Width="104"
                                Margin="0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                Background="#FFF7EB"
                                CornerRadius="24"
                                IsHitTestVisible="False"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform X="0" />
                            </Border.RenderTransform>
                        </Border>

                        <Button x:Name="CurrentDataSwitchButton"
                                Grid.Column="0"
                                Width="104"
                                Padding="18,10"
                                Click="CurrentDataSwitchButton_OnClick"
                                Command="{Binding ShowCurrentDataCommand}"
                                Content="当前">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="#D5E5DA" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="FontSize" Value="24" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RootBorder"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="24">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                <Condition Binding="{Binding IsCurrentDataMode}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#31574D" />
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsCurrentDataMode}" Value="True">
                                            <Setter Property="Foreground" Value="#15312B" />
                                            <Setter Property="Background" Value="#FFF7EB" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button x:Name="HistoryDataSwitchButton"
                                Grid.Column="2"
                                Width="104"
                                Padding="18,10"
                                Click="HistoryDataSwitchButton_OnClick"
                                Command="{Binding ShowHistoryDataCommand}"
                                Content="历史">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Foreground" Value="#D5E5DA" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="FontSize" Value="24" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RootBorder"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="24">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True" />
                                                <Condition Binding="{Binding IsHistoryDataMode}" Value="False" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#31574D" />
                                        </MultiDataTrigger>
                                        <DataTrigger Binding="{Binding IsHistoryDataMode}" Value="True">
                                            <Setter Property="Foreground" Value="#15312B" />
                                            <Setter Property="Background" Value="#FFF7EB" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </Border>

                <Border Grid.Column="6"
                        Padding="16"
                        Background="#25433C"
                        CornerRadius="20">
                    <StackPanel>
                        <TextBlock Foreground="#D5E5DA"
                                   FontSize="12"
                                   Text="展示选项" />
                        <Menu Margin="0,10,0,0"
                              Style="{StaticResource OverviewMenuStyle}">
                            <Menu.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#31574D" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#31574D" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#25433C" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.MenuTextBrushKey}" Color="#FFF7EC" />
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFF7EC" />
                                <Style TargetType="MenuItem" BasedOn="{StaticResource OverviewMenuItemStyle}" />
                            </Menu.Resources>
                            <MenuItem Header="网络"
                                      Style="{StaticResource OverviewMenuItemStyle}">
                                <MenuItem Header="隐藏"
                                          Command="{Binding SetNetworkHiddenDisplayCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsNetworkHiddenMode, Mode=OneWay}" />
                                <MenuItem Header="总量"
                                          Command="{Binding SetNetworkTotalDisplayCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsNetworkTotalMode, Mode=OneWay}" />
                                <MenuItem Header="分离"
                                          Command="{Binding SetNetworkSplitDisplayCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsNetworkSplitMode, Mode=OneWay}" />
                            </MenuItem>
                            <MenuItem Header="应用 I/O"
                                      Margin="10,0,0,0"
                                      Style="{StaticResource OverviewMenuItemStyle}">
                                <MenuItem Header="隐藏"
                                          Command="{Binding SetIoHiddenDisplayCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsIoHiddenMode, Mode=OneWay}" />
                                <MenuItem Header="总量"
                                          Command="{Binding SetIoTotalDisplayCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsIoTotalMode, Mode=OneWay}" />
                                <MenuItem Header="分离"
                                          Command="{Binding SetIoSplitDisplayCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsIoSplitMode, Mode=OneWay}" />
                            </MenuItem>
                            <MenuItem Header="绘图尺度"
                                      Margin="10,0,0,0">
                                <MenuItem.Style>
                                    <Style TargetType="MenuItem" BasedOn="{StaticResource OverviewMenuItemStyle}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCurrentDataMode}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </MenuItem.Style>
                                <MenuItem Header="30秒"
                                          Command="{Binding SetChartScale30SecondsCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsChartScale30SecondsMode, Mode=OneWay}" />
                                <MenuItem Header="1分钟"
                                          Command="{Binding SetChartScale1MinuteCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsChartScale1MinuteMode, Mode=OneWay}" />
                                <MenuItem Header="2分钟"
                                          Command="{Binding SetChartScale2MinutesCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsChartScale2MinutesMode, Mode=OneWay}" />
                            </MenuItem>
                            <MenuItem Header="叠加方式"
                                      Margin="10,0,0,0">
                                <MenuItem.Style>
                                    <Style TargetType="MenuItem" BasedOn="{StaticResource OverviewMenuItemStyle}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHistoryDataMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </MenuItem.Style>
                                <MenuItem Header="关闭"
                                          Command="{Binding SetHistoryOverlayOffCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsHistoryOverlayOffMode, Mode=OneWay}" />
                                <MenuItem Header="使用时长"
                                          Command="{Binding SetHistoryOverlayUsageDurationCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsHistoryOverlayUsageDurationMode, Mode=OneWay}" />
                                <MenuItem Header="前台时长"
                                          Command="{Binding SetHistoryOverlayForegroundDurationCommand}"
                                          IsCheckable="True"
                                          IsChecked="{Binding IsHistoryOverlayForegroundDurationMode, Mode=OneWay}" />
                            </MenuItem>
                        </Menu>
                        
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              x:Name="DetailContentHost"
              ClipToBounds="True">
            <ScrollViewer x:Name="CurrentDataPanel"
                          Panel.ZIndex="1"
                          Opacity="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.RenderTransform>
                    <TranslateTransform X="0" />
                </ScrollViewer.RenderTransform>
                <StackPanel>
                <Border Padding="0"
                        Background="#FFFDF9"
                        CornerRadius="24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Padding="18"
                                Background="#FFF8EF"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock Foreground="#7B7F74"
                                           FontSize="12"
                                           Text="{Binding NetworkChartTitle}" />
                                <Grid Height="20"
                                      Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid>
                                        <TextBlock Foreground="#506057"
                                                   VerticalAlignment="Center"
                                                   Opacity="0"
                                                   IsHitTestVisible="False"
                                                   Text="当前已隐藏网络图表" />
                                        <TextBlock Foreground="#506057"
                                                   VerticalAlignment="Center"
                                                   Text="当前已隐藏网络图表"
                                                   Visibility="{Binding ShowNetworkHiddenNotice, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Visibility="{Binding ShowNetworkLegend, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="10"
                                                    Height="10"
                                                    Margin="0,0,6,0"
                                                    Background="#2D8CFF"
                                                    CornerRadius="5" />
                                            <TextBlock Foreground="#506057"
                                                       FontSize="11"
                                                       Text="{Binding NetworkPrimaryLegendLabel}" />
                                        </StackPanel>
                                        <StackPanel Margin="14,0,0,0"
                                                    Orientation="Horizontal">
                                            <Border Width="10"
                                                    Height="10"
                                                    Margin="0,0,6,0"
                                                    Background="#FF8A3D"
                                                    CornerRadius="5" />
                                            <TextBlock Foreground="#506057"
                                                       FontSize="11"
                                                       Text="{Binding NetworkSecondaryLegendLabel}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Margin="0,12,0,0"
                                            Visibility="{Binding ShowNetworkChart, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Border Height="194"
                                            CornerRadius="14"
                                            ClipToBounds="True"
                                            Background="#FFF8EF">
                                        <Grid>
                                            <Image Margin="-26,-12,-7,36"
                                                   Height="180"
                                                   VerticalAlignment="Top"
                                                   Stretch="Fill"
                                                   Source="{Binding NetworkChartSource}" />

                                            <TextBlock Margin="8,6,0,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                       Foreground="#7B7F74"
                                                       FontSize="10"
                                                       Background="#CCFFF8EF"
                                                       Text="{Binding NetworkChartTopLabel}" />
                                            <TextBlock Margin="8,0,0,30"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Bottom"
                                                       Foreground="#7B7F74"
                                                       FontSize="10"
                                                       Background="#CCFFF8EF"
                                                       Text="{Binding NetworkChartBottomLabel}" />

                                            <Grid Margin="8,0,8,6"
                                                  VerticalAlignment="Bottom">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#7B7F74"
                                                           FontSize="10"
                                                           Text="{Binding ChartXAxisStartLabel}" />
                                                <TextBlock Grid.Column="1"
                                                           HorizontalAlignment="Center"
                                                           Foreground="#7B7F74"
                                                           FontSize="10"
                                                           Text="{Binding ChartXAxisCenterLabel}" />
                                                <TextBlock Grid.Column="2"
                                                           Foreground="#7B7F74"
                                                           FontSize="10"
                                                           Text="{Binding ChartXAxisEndLabel}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Padding="18"
                                Background="#F7FBF6"
                                CornerRadius="18">
                            <StackPanel>
                                <TextBlock Foreground="#7B7F74"
                                           FontSize="12"
                                           Text="{Binding IoChartTitle}" />
                                <Grid Height="20"
                                      Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Grid>
                                        <TextBlock Foreground="#506057"
                                                   VerticalAlignment="Center"
                                                   Opacity="0"
                                                   IsHitTestVisible="False"
                                                   Text="当前已隐藏 I/O 图表" />
                                        <TextBlock Foreground="#506057"
                                                   VerticalAlignment="Center"
                                                   Text="当前已隐藏 I/O 图表"
                                                   Visibility="{Binding ShowIoHiddenNotice, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    </Grid>
                                    <StackPanel Grid.Column="1"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Visibility="{Binding ShowIoLegend, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="10"
                                                    Height="10"
                                                    Margin="0,0,6,0"
                                                    Background="#17766C"
                                                    CornerRadius="5" />
                                            <TextBlock Foreground="#506057"
                                                       FontSize="11"
                                                       Text="{Binding IoPrimaryLegendLabel}" />
                                        </StackPanel>
                                        <StackPanel Margin="14,0,0,0"
                                                    Orientation="Horizontal">
                                            <Border Width="10"
                                                    Height="10"
                                                    Margin="0,0,6,0"
                                                    Background="#D06A43"
                                                    CornerRadius="5" />
                                            <TextBlock Foreground="#506057"
                                                       FontSize="11"
                                                       Text="{Binding IoSecondaryLegendLabel}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Margin="0,12,0,0"
                                            Visibility="{Binding ShowIoChart, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Border Height="194"
                                            CornerRadius="14"
                                            ClipToBounds="True"
                                            Background="#F7FBF6">
                                        <Grid>
                                            <Image Margin="-33,-12,-7,36.7"
                                                   Height="180"
                                                   VerticalAlignment="Top"
                                                   Stretch="Fill"
                                                   Source="{Binding IoChartSource}" />

                                            <TextBlock Margin="8,6,0,0"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Top"
                                                       Foreground="#7B7F74"
                                                       FontSize="10"
                                                       Background="#CCF7FBF6"
                                                       Text="{Binding IoChartTopLabel}" />
                                            <TextBlock Margin="8,0,0,30"
                                                       HorizontalAlignment="Left"
                                                       VerticalAlignment="Bottom"
                                                       Foreground="#7B7F74"
                                                       FontSize="10"
                                                       Background="#CCF7FBF6"
                                                       Text="{Binding IoChartBottomLabel}" />

                                            <Grid Margin="8,0,8,6"
                                                  VerticalAlignment="Bottom">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#7B7F74"
                                                           FontSize="10"
                                                           Text="{Binding ChartXAxisStartLabel}" />
                                                <TextBlock Grid.Column="1"
                                                           HorizontalAlignment="Center"
                                                           Foreground="#7B7F74"
                                                           FontSize="10"
                                                           Text="{Binding ChartXAxisCenterLabel}" />
                                                <TextBlock Grid.Column="2"
                                                           Foreground="#7B7F74"
                                                           FontSize="10"
                                                           Text="{Binding ChartXAxisEndLabel}" />
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Border Margin="0,16,0,0"
                        Padding="22"
                        Background="#FFFDF9"
                        CornerRadius="24">
                    <StackPanel>
                        <TextBlock Foreground="#7B7F74"
                                   FontSize="13"
                                   Text="前后台概况" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="16"
                                    Background="#F5EFE3"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock Foreground="#7B7F74"
                                               FontSize="12"
                                               Text="今日前台" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding ForegroundDurationDisplay}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#506057"
                                               Text="{Binding AverageForegroundCpuDisplay, StringFormat=平均 CPU {0}}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#506057"
                                               Text="{Binding AverageForegroundWorkingSetDisplay, StringFormat=平均内存 {0}}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Foreground="#506057"
                                               Text="{Binding AverageForegroundIopsDisplay, StringFormat=日均前台 IOPS {0}}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Padding="16"
                                    Background="#EEF3ED"
                                    CornerRadius="18">
                                <StackPanel>
                                    <TextBlock Foreground="#7B7F74"
                                               FontSize="12"
                                               Text="今日后台" />
                                    <TextBlock Margin="0,8,0,0"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Text="{Binding BackgroundDurationDisplay}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="#506057"
